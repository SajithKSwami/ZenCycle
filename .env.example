# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Gemini API key — backend use only, never expose to frontend
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Admin SDK credentials (backend only)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# CORS — set to your frontend origin in production
CLIENT_ORIGIN=http://localhost:3000

# Server port (optional, defaults to 3000)
PORT=3000
