rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isEmailVerified() { return request.auth.token.email_verified == true; }

    // ── User-scoped data (/users/{uid}/...) ───────────────────────────────────
    // Profile, daily state, history, calendar — owner only.

    match /users/{uid}/data/{docId} {
      allow read, write: if isOwner(uid);
    }

    match /users/{uid}/daily/{date} {
      allow read, write: if isOwner(uid);
    }

    match /users/{uid}/history/{date} {
      allow read, write: if isOwner(uid);
    }

    match /users/{uid}/calendar/{entryId} {
      allow read, write: if isOwner(uid);
    }

    // ── Journal entries ───────────────────────────────────────────────────────
    match /journalEntries/{entryId} {
      function isValidJournal(data) {
        return data.userId == request.auth.uid
          && data.achievement is string && data.achievement.size() <= 2000
          && data.learnings is list && data.learnings.size() <= 10
          && data.goodMoments is list && data.goodMoments.size() <= 10
          && data.okMoments is list && data.okMoments.size() <= 10
          && data.sadMoments is list && data.sadMoments.size() <= 10
          && data.reflectionSummary is string && data.reflectionSummary.size() <= 5000
          && (!('moodScore' in data) || (data.moodScore is int && data.moodScore >= 1 && data.moodScore <= 11));
      }

      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isEmailVerified() && isValidId(entryId) && isValidJournal(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['achievement', 'learnings', 'goodMoments', 'okMoments', 'sadMoments', 'reflectionSummary', 'moodScore', 'updatedAt']);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ── Break sessions ────────────────────────────────────────────────────────
    match /breakSessions/{sessionId} {
      function isValidBreak(data) {
        return data.userId == request.auth.uid
          && data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$')
          && data.startTime is string
          && data.durationSeconds is int && data.durationSeconds >= 0
          && (!('notes' in data) || (data.notes is string && data.notes.size() <= 1000));
      }

      allow get, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isEmailVerified() && isValidId(sessionId) && isValidBreak(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['notes', 'endTime', 'durationSeconds', 'updatedAt']);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ── Daily break summaries ─────────────────────────────────────────────────
    match /dailyBreakSummaries/{summaryId} {
      allow read, write: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isEmailVerified()
        && request.resource.data.userId == request.auth.uid;
    }

    // ── Deny everything else ──────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
