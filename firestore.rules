rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} { allow read, write: if false; }

    // Phase 3: Primitive Definitions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }

    // 1. Journal Entry Rules
    match /journalEntries/{entryId} {
      function isValidJournal(data) {
        return data.userId == request.auth.uid &&
          data.dateTime is string && data.dateTime.size() <= 64 &&
          data.achievement is string && data.achievement.size() <= 2000 &&
          data.learnings is list && data.learnings.size() <= 10 &&
          data.goodMoments is list && data.goodMoments.size() <= 10 &&
          data.okMoments is list && data.okMoments.size() <= 10 &&
          data.sadMoments is list && data.sadMoments.size() <= 10 &&
          data.reflectionSummary is string && data.reflectionSummary.size() <= 5000 &&
          (!('moodScore' in data) || (data.moodScore is int && data.moodScore >= 1 && data.moodScore <= 11)) &&
          data.createdAt == request.time &&
          data.updatedAt == request.time;
      }

      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && isEmailVerified() && isValidId(entryId) &&
                      isValidJournal(incoming()) && 
                      incoming().keys().hasAll(['userId', 'dateTime', 'achievement', 'reflectionSummary', 'createdAt', 'updatedAt']) &&
                      incoming().keys().size() >= 6;

      allow update: if isOwner(existing().userId) && 
                      incoming().userId == existing().userId &&
                      incoming().createdAt == existing().userId &&
                      incoming().updatedAt == request.time &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['achievement', 'learnings', 'goodMoments', 'okMoments', 'sadMoments', 'reflectionSummary', 'moodScore', 'updatedAt']);

      allow delete: if isOwner(existing().userId);
    }

    // 2. Break Session Rules
    match /breakSessions/{sessionId} {
      function isValidBreak(data) {
        return data.userId == request.auth.uid &&
          data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
          data.startTime is string &&
          data.endTime is string &&
          data.durationSeconds is int && data.durationSeconds >= 0 &&
          (!('notes' in data) || (data.notes is string && data.notes.size() <= 1000)) &&
          data.createdAt == request.time;
      }

      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && isEmailVerified() && isValidId(sessionId) &&
                      isValidBreak(incoming()) &&
                      incoming().keys().hasAll(['userId', 'date', 'startTime', 'endTime', 'durationSeconds', 'createdAt']);

      allow update: if isOwner(existing().userId) && 
                      incoming().userId == existing().userId &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['notes', 'date', 'startTime', 'endTime', 'durationSeconds']);

      allow delete: if isOwner(existing().userId);
    }

    // 3. Daily Break Summary Rules (Aggregates)
    match /dailyBreakSummaries/{summaryId} {
      function isValidSummary(data) {
        return data.userId == request.auth.uid &&
          data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
          data.totalBreaks is int && data.totalBreaks >= 0 &&
          data.totalDurationSeconds is int && data.totalDurationSeconds >= 0 &&
          data.updatedAt == request.time;
      }

      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && isEmailVerified() && isValidId(summaryId) &&
                      isValidSummary(incoming());

      allow update: if isOwner(existing().userId) && 
                      incoming().userId == existing().userId &&
                      isValidSummary(incoming());

      allow delete: if isOwner(existing().userId);
    }
  }
}
